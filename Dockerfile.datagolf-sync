FROM node:20-bookworm-slim

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src ./src
COPY scripts ./scripts

# Keep the script as the container entrypoint so Cloud Run job args append to it
# instead of replacing Node's default CMD from the base image.
ENTRYPOINT ["npm", "run", "sync:datagolf:scores", "--"]
CMD ["--once"]
