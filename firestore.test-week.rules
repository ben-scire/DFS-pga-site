rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isApprovedUserSlug(userSlug) {
      return userSlug in [
        'wyaggy3',
        'abboduece22',
        'mtibaudo',
        'johncastronovo',
        'amac',
        'yimmerdoe',
        'cm30',
        'rohansharma99',
        'jvaccari33',
        'sam.scire',
        'capc',
        'boxmuncher',
        'jakdot2009',
        'dylangoody',
        'samthemaam5',
        'tomlinsonj15',
        'jpetruney',
        'bscire',
        'jake',
        'eions',
        'unccle-neal',
        'finsmaniac'
      ];
    }

    function isAllowedContest(contestId) {
      return contestId in ['week-1-cognizant', 'week-2-arnold-palmer', 'week-3-players'];
    }

    function isAdminUserSlug(userSlug) {
      return userSlug in ['finsmaniac', 'bscire', 'dylangoody'];
    }

    function isValidTestLineupPayload(data, contestId, userSlug) {
      return data.keys().hasOnly([
          'contestId',
          'userSlug',
          'userDisplayName',
          'lineupGolferIds',
          'submittedAtIso',
          'lastEditedAtIso',
          'updatedAt',
          'source',
          'version'
        ]) &&
        data.contestId == contestId &&
        data.userSlug == userSlug &&
        data.userDisplayName is string &&
        data.lineupGolferIds is list &&
        data.lineupGolferIds.size() <= 6 &&
        data.lastEditedAtIso is string &&
        (!('submittedAtIso' in data) || data.submittedAtIso is string) &&
        data.source == 'web-test' &&
        data.version == 1;
    }


    function isValidTestScorePayload(data, contestId, golferId) {
      return data.keys().hasOnly([
          'contestId',
          'golferId',
          'position',
          'scoreToPar',
          'thru',
          'today',
          'status',
          'fantasyPoints',
          'scoringSource',
          'updatedAt',
          'updatedBySlug',
          'finalScoreLocked',
          'manualFantasyPoints',
          'manualScoreNote'
        ]) &&
        data.contestId == contestId &&
        data.golferId == golferId &&
        (!('position' in data) || data.position is string) &&
        (!('scoreToPar' in data) || data.scoreToPar is int || data.scoreToPar is float || data.scoreToPar is string) &&
        (!('thru' in data) || data.thru is int || data.thru is string) &&
        (!('today' in data) || data.today is int || data.today is float || data.today is string) &&
        (!('status' in data) || data.status is string) &&
        (!('fantasyPoints' in data) || data.fantasyPoints is int || data.fantasyPoints is float || data.fantasyPoints == null) &&
        (!('scoringSource' in data) || data.scoringSource is string) &&
        data.updatedBySlug is string &&
        isAdminUserSlug(data.updatedBySlug) &&
        (!('finalScoreLocked' in data) || data.finalScoreLocked is bool) &&
        (!('manualFantasyPoints' in data) || data.manualFantasyPoints is int || data.manualFantasyPoints is float || data.manualFantasyPoints == null) &&
        (!('manualScoreNote' in data) || data.manualScoreNote is string);
    }

    function isValidPaymentStatusPayload(data, userSlug) {
      return data.keys().hasOnly([
          'userSlug',
          'userDisplayName',
          'week1Paid',
          'week2Paid',
          'quarter1Paid',
          'paid',
          'updatedByUid',
          'updatedBySlug',
          'updatedAt'
        ]) &&
        data.userSlug == userSlug &&
        isApprovedUserSlug(userSlug) &&
        data.userDisplayName is string &&
        (!('week1Paid' in data) || data.week1Paid is bool) &&
        (!('week2Paid' in data) || data.week2Paid is bool) &&
        (!('quarter1Paid' in data) || data.quarter1Paid is bool) &&
        (!('paid' in data) || data.paid is bool) &&
        (!('updatedByUid' in data) || data.updatedByUid is string) &&
        data.updatedBySlug is string &&
        isAdminUserSlug(data.updatedBySlug);
    }

    match /test_users/{uid} {
      allow read, write: if false;
      allow delete: if false;
    }

    match /test_lineups/{contestId}/entries/{userSlug} {
      allow read: if isAllowedContest(contestId) && isApprovedUserSlug(userSlug);
      allow create, update: if isAllowedContest(contestId) &&
        isApprovedUserSlug(userSlug) &&
        isValidTestLineupPayload(request.resource.data, contestId, userSlug);
      allow delete: if false;
    }

    match /test_scores/{contestId}/golfers/{golferId} {
      allow read: if isAllowedContest(contestId);
      allow create, update: if isAllowedContest(contestId) &&
        isValidTestScorePayload(request.resource.data, contestId, golferId);
      allow delete: if false;
    }

    match /test_payment_status/{userSlug} {
      allow read: if isApprovedUserSlug(userSlug);
      allow create, update: if isApprovedUserSlug(userSlug) &&
        isValidPaymentStatusPayload(request.resource.data, userSlug);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
