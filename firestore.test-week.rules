rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isApprovedUserSlug(userSlug) {
      return userSlug in [
        'wyaggy3',
        'abboduece22',
        'mtibaudo',
        'johncastronovo',
        'cm30',
        'rohansharma99',
        'jvaccari33',
        'sam.scire',
        'capc',
        'boxmuncher',
        'jakdot2009',
        'dylangoody',
        'samthemaam5',
        'tomlinsonj15',
        'jpetruney',
        'bscire',
        'jake',
        'eions',
        'unccle-neal',
        'finsmaniac'
      ];
    }

    function isAllowedContest(contestId) {
      return contestId in ['week-1-cognizant', 'week-2-arnold-palmer'];
    }

    function isAdminUserSlug(userSlug) {
      return userSlug in ['finsmaniac', 'bscire', 'dylangoody'];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnProfile(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidProfilePayload(data, uid) {
      return data.keys().hasOnly(['uid', 'userSlug', 'createdAt', 'updatedAt']) &&
        data.uid == uid &&
        data.userSlug is string &&
        isApprovedUserSlug(data.userSlug);
    }

    function authUserSlug() {
      return get(/databases/$(database)/documents/test_users/$(request.auth.uid)).data.userSlug;
    }

    function authSlugMatches(userSlug) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/test_users/$(request.auth.uid)) &&
        authUserSlug() == userSlug;
    }

    function isAdminAuth() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/test_users/$(request.auth.uid)) &&
        isAdminUserSlug(authUserSlug());
    }

    function isValidTestLineupPayload(data, contestId, userSlug) {
      return data.keys().hasOnly([
          'contestId',
          'userSlug',
          'userDisplayName',
          'lineupGolferIds',
          'submittedAtIso',
          'lastEditedAtIso',
          'updatedAt',
          'source',
          'version'
        ]) &&
        data.contestId == contestId &&
        data.userSlug == userSlug &&
        data.userDisplayName is string &&
        data.lineupGolferIds is list &&
        data.lineupGolferIds.size() <= 6 &&
        data.lastEditedAtIso is string &&
        (!('submittedAtIso' in data) || data.submittedAtIso is string) &&
        data.source == 'web-test' &&
        data.version == 1;
    }

    function isValidPaymentStatusPayload(data, userSlug) {
      return data.keys().hasOnly([
          'userSlug',
          'userDisplayName',
          'paid',
          'updatedByUid',
          'updatedBySlug',
          'updatedAt'
        ]) &&
        data.userSlug == userSlug &&
        isApprovedUserSlug(userSlug) &&
        data.userDisplayName is string &&
        data.paid is bool &&
        data.updatedByUid == request.auth.uid &&
        data.updatedBySlug == authUserSlug();
    }

    match /test_users/{uid} {
      allow read: if isOwnProfile(uid);
      allow create: if isOwnProfile(uid) && isValidProfilePayload(request.resource.data, uid);
      allow update: if isOwnProfile(uid) &&
        resource.data.userSlug == request.resource.data.userSlug &&
        isValidProfilePayload(request.resource.data, uid);
      allow delete: if false;
    }

    match /test_lineups/{contestId}/entries/{userSlug} {
      allow read: if isSignedIn() && isAllowedContest(contestId) && isApprovedUserSlug(userSlug);
      allow create, update: if isAllowedContest(contestId) &&
        isApprovedUserSlug(userSlug) &&
        authSlugMatches(userSlug) &&
        isValidTestLineupPayload(request.resource.data, contestId, userSlug);
      allow delete: if false;
    }

    match /test_scores/{contestId}/golfers/{golferId} {
      allow read: if isSignedIn() && isAllowedContest(contestId);
      allow write: if false;
    }

    match /test_payment_status/{userSlug} {
      allow read: if isSignedIn() && isApprovedUserSlug(userSlug);
      allow create, update: if isApprovedUserSlug(userSlug) &&
        isAdminAuth() &&
        isValidPaymentStatusPayload(request.resource.data, userSlug);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
