# Required for live DFS data. If empty, the app falls back to mock data when enabled.
NEXT_PUBLIC_DFS_API_BASE_URL=

# Used when NEXT_PUBLIC_DFS_API_PATH contains {contestId}.
NEXT_PUBLIC_DFS_CONTEST_ID=

# Path template relative to base URL.
# Example: /contests/{contestId}/live
NEXT_PUBLIC_DFS_API_PATH=/contests/{contestId}/live

# Optional SSE endpoint for true push updates.
# Example: /contests/{contestId}/stream
NEXT_PUBLIC_DFS_STREAM_PATH=/contests/{contestId}/stream

# Optional API auth settings.
NEXT_PUBLIC_DFS_API_KEY=
NEXT_PUBLIC_DFS_API_KEY_HEADER=x-api-key

# Refresh cadence in milliseconds (default: 60000).
NEXT_PUBLIC_DFS_REFRESH_MS=60000

# Fallback to src/lib/mock-data.ts when API config/errors occur.
NEXT_PUBLIC_USE_MOCK_FALLBACK=true
